<Window x:Class="Orbital.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="620" Height="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResize">

    <Window.Resources>
        <!-- Override system colors for dark ComboBox popups -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>

        <!-- Dark ComboBox toggle button template -->
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Border x:Name="Bd" Background="#2A2A2A" BorderBrush="#444" BorderThickness="1"
                    CornerRadius="4" Padding="6,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                      Margin="2,0,0,0"/>
                    <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="White" StrokeThickness="1.5"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#363636"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Full dark ComboBox template -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="10,4,24,4"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}" SnapsToDevicePixels="True">
                                    <Border Background="#2A2A2A" BorderBrush="#555" BorderThickness="1"
                                            CornerRadius="4" Padding="0,2">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox popup item style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="10,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E" CornerRadius="14" BorderBrush="#333" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Background="#181818" CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid Margin="16,0">
                    <TextBlock Text="⚙  Settings" Foreground="White" FontSize="14"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" Click="Close_Click"
                            Background="#D94444" Style="{StaticResource SmallBtn}"
                            Content="✕" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,0">
                <StackPanel Margin="0,0,10,0">

                    <!-- ═══ APPEARANCE ═══ -->
                    <TextBlock Text="Appearance" Style="{StaticResource SectionHeader}"/>

                    <TextBlock Text="Theme" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="ThemeCombo" Margin="0,0,0,8">
                        <ComboBoxItem Content="Dark"/>
                        <ComboBoxItem Content="Light"/>
                    </ComboBox>

                    <TextBlock Text="Accent Color (hex)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="AccentBox" Style="{StaticResource FieldBox}" Margin="0,0,0,8"/>

                    <TextBlock Text="Island Shape" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="ShapeCombo" Margin="0,0,0,8">
                        <ComboBoxItem Content="Pill"/>
                        <ComboBoxItem Content="Rectangle"/>
                        <ComboBoxItem Content="Rounded"/>
                    </ComboBox>

                    <TextBlock Text="Corner Radius" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="CornerRadiusBox" Style="{StaticResource FieldBox}" Margin="0,0,0,8"/>

                    <TextBlock Text="Island Scale (0.5 – 2.0)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="ScaleBox" Style="{StaticResource FieldBox}" Margin="0,0,0,8"/>

                    <TextBlock Text="Outline Color (hex, leave empty for none)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="OutlineColorBox" Style="{StaticResource FieldBox}" Margin="0,0,0,8"/>

                    <TextBlock Text="Background Image Path (optional)" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="BgImageBox" Style="{StaticResource FieldBox}"/>
                        <Button Grid.Column="1" Content="Browse" Background="#444"
                                Style="{StaticResource SmallBtn}" Click="BrowseBgImage_Click"
                                Margin="4,0,0,0"/>
                    </Grid>

                    <!-- ═══ POSITION / SIZE ═══ -->
                    <TextBlock Text="Position &amp; Size" Style="{StaticResource SectionHeader}"/>

                    <TextBlock Text="Island Position" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="PositionCombo" Margin="0,0,0,8"
                              SelectionChanged="PositionCombo_Changed">
                        <ComboBoxItem Content="TopCenter"/>
                        <ComboBoxItem Content="TopLeft"/>
                        <ComboBoxItem Content="TopRight"/>
                        <ComboBoxItem Content="Left"/>
                        <ComboBoxItem Content="Right"/>
                        <ComboBoxItem Content="Custom"/>
                    </ComboBox>

                    <StackPanel x:Name="CustomPositionPanel" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="Custom Top (px)" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="CustomTopBox" Style="{StaticResource FieldBox}" Margin="0,0,0,4"/>
                        <TextBlock Text="Custom Left (px)" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="CustomLeftBox" Style="{StaticResource FieldBox}"/>
                        <TextBlock Text="Tip: You can also drag the collapsed island to any position."
                                   Foreground="#666" FontSize="10" FontStyle="Italic" Margin="0,4,0,0"/>
                    </StackPanel>

                    <TextBlock Text="Collapsed Width" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="WidthBox" Style="{StaticResource FieldBox}" Margin="0,0,0,8"/>

                    <TextBlock Text="Workspace Header Height (px)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="HeaderHeightBox" Style="{StaticResource FieldBox}" Margin="0,0,0,8"/>

                    <CheckBox x:Name="BlendIslandCheck" Content="Blend island info into workspace header"
                              Foreground="#AAA" FontSize="12" Margin="0,0,0,8"/>

                    <!-- ═══ AUTO-HIDE ═══ -->
                    <TextBlock Text="Auto-hide" Style="{StaticResource SectionHeader}"/>

                    <CheckBox x:Name="AutoHideCheck" Content="Enable auto-hide (island slides away when not in use)"
                              Foreground="#AAA" FontSize="12" Margin="0,0,0,8"/>

                    <TextBlock Text="Hide Edge" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="AutoHideEdgeCombo" Margin="0,0,0,8">
                        <ComboBoxItem Content="Top"/>
                        <ComboBoxItem Content="Left"/>
                        <ComboBoxItem Content="Right"/>
                    </ComboBox>

                    <!-- ═══ SYSTEM INFO ═══ -->
                    <TextBlock Text="System Info" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="CPU / RAM refresh interval (seconds, min 1)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="SysRefreshBox" Style="{StaticResource FieldBox}" Margin="0,0,0,8"/>

                    <!-- ═══ STARTUP ═══ -->
                    <TextBlock Text="Startup" Style="{StaticResource SectionHeader}"/>

                    <CheckBox x:Name="StartOnBootCheck" Content="Launch Orbital on Windows startup"
                              Foreground="#AAA" FontSize="12" Margin="0,0,0,8"/>

                    <!-- ═══ SCHEDULE ═══ -->
                    <TextBlock Text="Class Schedule" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="Set up a day-based schedule. Choose cycle length and select a day to manage its periods."
                               Foreground="#777" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <!-- Cycle length -->
                    <TextBlock Text="Schedule Cycle" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="CycleWeeksCombo" Margin="0,0,0,8"
                              SelectionChanged="CycleWeeks_Changed">
                        <ComboBoxItem Content="1 Week"/>
                        <ComboBoxItem Content="2 Weeks"/>
                        <ComboBoxItem Content="3 Weeks"/>
                    </ComboBox>

                    <!-- Week selector (visible for 2+ week cycles) -->
                    <WrapPanel x:Name="WeekButtonsPanel" Margin="0,0,0,6" Visibility="Collapsed"/>

                    <!-- Day selector -->
                    <TextBlock Text="Select Day" Style="{StaticResource LabelStyle}"/>
                    <WrapPanel x:Name="DayButtonsPanel" Margin="0,0,0,8"/>

                    <!-- Period list for selected day/week -->
                    <ItemsControl x:Name="ScheduleList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2A2A2A" CornerRadius="8" Padding="8,4" Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="14"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource FieldBox}" Margin="0,0,6,0"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding StartTime, UpdateSourceTrigger=LostFocus}"
                                                 Style="{StaticResource FieldBox}" TextAlignment="Center"
                                                 ToolTip="e.g. 8:00 AM"/>
                                        <TextBlock Grid.Column="2" Text="–" Foreground="#888"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBox Grid.Column="3"
                                                 Text="{Binding EndTime, UpdateSourceTrigger=LostFocus}"
                                                 Style="{StaticResource FieldBox}" TextAlignment="Center"
                                                 ToolTip="e.g. 8:50 AM"/>
                                        <Button Grid.Column="4" Content="✕" Background="#D94444"
                                                Style="{StaticResource SmallBtn}"
                                                Tag="{Binding}" Click="RemoveSchedule_Click" Margin="4,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="+ Add Period" Background="#333" Margin="0,4,0,0"
                            HorizontalAlignment="Left" Style="{StaticResource SmallBtn}"
                            Click="AddSchedule_Click"/>

                    <!-- ═══ WORKSPACES ═══ -->
                    <TextBlock Text="Workspaces" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="Configure workspaces, their colors, panel URLs, and split layout."
                               Foreground="#777" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>

                    <ItemsControl x:Name="SubjectList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2A2A2A" CornerRadius="10" Padding="10,8" Margin="0,3">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FieldBox}" FontWeight="SemiBold"
                                                     Margin="0,0,6,0"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Color, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FieldBox}" TextAlignment="Center"/>
                                            <ComboBox Grid.Column="2"
                                                       SelectedValue="{Binding SplitOrientation}"
                                                       SelectedValuePath="Content"
                                                       Margin="6,0,0,0">
                                                <ComboBoxItem Content="LeftRight"/>
                                                <ComboBoxItem Content="TopBottom"/>
                                                <ComboBoxItem Content="Mixed"/>
                                            </ComboBox>
                                            <Button Grid.Column="3" Content="✕" Background="#D94444"
                                                    Style="{StaticResource SmallBtn}"
                                                    Tag="{Binding}" Click="RemoveSubject_Click" Margin="6,0,0,0"/>
                                        </Grid>
                                        <!-- Panels -->
                                        <ItemsControl ItemsSource="{Binding Panels}" Margin="0,4,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="90"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="40"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource FieldBox}" FontSize="11"
                                                                 Margin="0,0,4,0"/>
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource FieldBox}" FontSize="11"/>
                                                        <TextBox Grid.Column="2"
                                                                 Text="{Binding LayoutGroup, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource FieldBox}" FontSize="11"
                                                                 TextAlignment="Center" ToolTip="Layout Group (column #)"
                                                                 Margin="4,0,0,0"/>
                                                        <Button Grid.Column="3" Content="✕" Background="#555"
                                                                Style="{StaticResource SmallBtn}" FontSize="10"
                                                                Tag="{Binding}" Click="RemovePanel_Click" Margin="4,0,0,0"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Content="+ Panel" Background="#444" Margin="0,4,0,0"
                                                HorizontalAlignment="Left" Style="{StaticResource SmallBtn}"
                                                FontSize="11" Tag="{Binding}" Click="AddPanel_Click"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="+ Add Workspace" Background="#333" Margin="0,6,0,16"
                            HorizontalAlignment="Left" Style="{StaticResource SmallBtn}"
                            Click="AddSubject_Click"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#181818" CornerRadius="0,0,14,14" Padding="20,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Cancel" Background="#555" Style="{StaticResource SmallBtn}"
                            Click="Close_Click" Margin="0,0,8,0"/>
                    <Button Content="Save &amp; Apply" Background="#4A90D9"
                            Style="{StaticResource SmallBtn}" Click="Save_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
