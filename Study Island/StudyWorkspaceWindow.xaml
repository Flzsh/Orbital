<Window x:Class="Orbital.WorkspaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workspace" WindowState="Maximized"
        WindowStyle="None" Background="#0D0D0D">

    <Window.Resources>
        <Style x:Key="TinyBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="6,2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="HeaderRow" Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Compact Title Bar with blended island info ═══ -->
        <Border x:Name="TitleBarBorder" Grid.Row="0" Background="#151515"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Click="BackButton_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" Padding="8,3">
                                <TextBlock Text="← Back" Foreground="#AAA" FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#222"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Island info blended into header -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <Ellipse x:Name="HeaderStatusDot" Width="7" Height="7"
                             Fill="#00FF88" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="HeaderClockText" Text="" Foreground="#CCC"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="HeaderTimerText" Text="" Foreground="#888"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="SubjectTitle" Grid.Column="2" Text="Workspace"
                           Foreground="White" FontSize="13" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="AddPanelBtn" Content="+ Panel" Background="#333"
                            Style="{StaticResource TinyBtn}" Click="AddPanel_Click"
                            Margin="0,0,4,0"/>
                    <Button x:Name="MaximizeBtn" Content="⬜" Background="#333" Style="{StaticResource TinyBtn}"
                            Click="ToggleMaximize_Click" Margin="0,0,4,0"/>
                    <Button Content="✕" Background="#D94444" Style="{StaticResource TinyBtn}"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Dynamic panel area – built in code-behind ═══ -->
        <Grid x:Name="PanelHost" Grid.Row="1" Margin="3"
              AllowDrop="True" Drop="PanelHost_Drop"/>
    </Grid>
</Window>
