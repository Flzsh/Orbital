<Window x:Class="Orbital.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orbital"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp">

    <Window.Resources>
        <!-- Subject button -->
        <Style x:Key="SubjectButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="12" Padding="18,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pill button -->
        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="14" Padding="12,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon button -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="6,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" Background="#1E1E1E"
            CornerRadius="25" BorderBrush="#333" BorderThickness="1" Margin="15"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="IslandScaleTransform" ScaleX="1" ScaleY="1"/>
                <TranslateTransform x:Name="IslandSlideTransform"/>
            </TransformGroup>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.6" Color="Black"/>
        </Border.Effect>

        <Grid>
            <!-- ═══════════════ COLLAPSED VIEW ═══════════════ -->
            <Border x:Name="CollapsedView" Padding="16,10" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="CollapsedTranslate"/>
                </Border.RenderTransform>
                <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Clock + Date (left) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,14,0">
                        <TextBlock x:Name="ClockText" Text="12:00 PM"
                                   Foreground="White" FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="DateText" Text="Mon, Jan 1"
                                   Foreground="#888" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Battery indicator -->
                    <TextBlock x:Name="BatteryText" Grid.Column="1" Text="🔋--"
                               Foreground="#888" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>

                    <!-- Timer / schedule text -->
                    <TextBlock x:Name="CollapsedTimerText" Grid.Column="2"
                               Text="" Foreground="#CCC"
                               FontSize="13" VerticalAlignment="Center"/>

                    <!-- Audio spectrum visualizer -->
                    <Border x:Name="SpectrumBorder" Grid.Column="2" Height="18"
                            Visibility="Collapsed" VerticalAlignment="Center"
                            ClipToBounds="True" Margin="4,0">
                        <Grid Width="140">
                            <Polygon x:Name="SpectrumFill" Opacity="0.25"/>
                            <Polyline x:Name="SpectrumLine" StrokeThickness="1.5"/>
                        </Grid>
                    </Border>

                    <!-- Reminder badge -->
                    <Border x:Name="ReminderBadge" Grid.Column="3"
                            Background="#FF6B6B" CornerRadius="9"
                            Padding="7,2" VerticalAlignment="Center"
                            Visibility="Collapsed" Margin="8,0,0,0">
                        <TextBlock x:Name="ReminderCountText" Text="0"
                                   Foreground="White" FontSize="10" FontWeight="Bold"/>
                    </Border>

                    <TextBlock Grid.Column="4" Text="▾" Foreground="#555"
                               FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>

                <!-- Inline collapsed reminder toast -->
                <Border x:Name="CollapsedReminderToast" Background="#FF6B6B" CornerRadius="10"
                        Padding="10,6" Margin="0,6,0,0" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔔" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="CollapsedReminderText" Grid.Column="1" Text=""
                                   Foreground="White" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="340"/>
                        <Button x:Name="CollapsedReminderDismissBtn" Grid.Column="2" Content="✕" Background="Transparent"
                                Foreground="White" BorderThickness="0" FontSize="11"
                                Cursor="Hand" Click="DismissCollapsedToast_Click"
                                Padding="4,2" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                </StackPanel>
            </Border>

            <!-- ═══════════════ EXPANDED VIEW ═══════════════ -->
            <Border x:Name="ExpandedView" Visibility="Collapsed" Padding="20,14"
                    RenderTransformOrigin="0.5,0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ExpandedTranslate"/>
                </Border.RenderTransform>
                <StackPanel MinWidth="440">

                    <!-- Reminder Toast (inline, non-blocking) -->
                    <Border x:Name="ReminderToast" Background="#FF6B6B" CornerRadius="10"
                            Padding="12,8" Margin="0,0,0,8" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔔" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ReminderToastText" Grid.Column="1" Text=""
                                       Foreground="White" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                            <Button Grid.Column="2" Content="✕" Background="Transparent"
                                    Foreground="White" BorderThickness="0" FontSize="12"
                                    Cursor="Hand" Click="DismissToast_Click"
                                    Padding="6,2" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Row 1: Clock + collapse + settings -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="ExpandedClockText"
                                       Foreground="White" FontSize="18" FontWeight="Bold"/>
                            <TextBlock x:Name="ExpandedDateText" Text="Mon, Jan 1"
                                       Foreground="#888" FontSize="12"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>

                        <Button x:Name="SettingsBtn" Grid.Column="2" Content="⚙" Background="#2A2A2A"
                                Style="{StaticResource IconBtn}" FontSize="15"
                                Click="Settings_Click" Margin="0,0,6,0"
                                ToolTip="Settings"/>
                        <Button x:Name="HideBtn" Grid.Column="3" Content="▽ Hide" Background="#2A2A2A"
                                Style="{StaticResource PillButtonStyle}"
                                Click="HideButton_Click" Margin="0,0,6,0"
                                ToolTip="Hide to edge"/>
                        <Button x:Name="CollapseBtn" Grid.Column="4" Content="▴" Background="#2A2A2A"
                                Style="{StaticResource PillButtonStyle}"
                                Click="CollapseButton_Click"/>
                    </Grid>

                    <!-- Audio spectrum (expanded) -->
                    <Border x:Name="ExpandedSpectrumBorder" Height="30"
                            Visibility="Visible" Opacity="0" ClipToBounds="True"
                            Margin="0,0,0,8" CornerRadius="10" Padding="4,2">
                        <Grid Width="420">
                            <Polygon x:Name="ExpandedSpectrumFill" Opacity="0.3"/>
                            <Polyline x:Name="ExpandedSpectrumLine" StrokeThickness="2"/>
                        </Grid>
                    </Border>

                    <!-- Row 2: Schedule countdown -->
                    <Border x:Name="ScheduleBar" Background="#2A2A2A" CornerRadius="10"
                            Padding="12,6" Margin="0,0,0,10" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ExpandedBatteryText" Text="🔋--"
                                       Foreground="#888" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ExpandedTimerText" Grid.Column="1"
                                       Text="" Foreground="White" FontSize="14"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ScheduleLabel" Grid.Column="2"
                                       Text="" Foreground="#888" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Row 3: Timer / Stopwatch toggle -->
                    <Border x:Name="TimerStopwatchBorder" Background="#2A2A2A" CornerRadius="12" Padding="12,8"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <!-- Tab row -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        Margin="0,0,0,6">
                                <Button x:Name="TimerTabBtn" Content="Timer"
                                        Background="#444" Style="{StaticResource IconBtn}"
                                        Click="TimerTab_Click" Margin="0,0,4,0" FontSize="12"/>
                                <Button x:Name="StopwatchTabBtn" Content="Stopwatch"
                                        Background="#333" Style="{StaticResource IconBtn}"
                                        Click="StopwatchTab_Click" FontSize="12"/>
                            </StackPanel>

                            <!-- Timer panel -->
                            <StackPanel x:Name="TimerPanel" Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <TextBlock x:Name="TimerIcon" Text="⏱" FontSize="15" Foreground="White"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox x:Name="TimerMinutesInput" Text="45" Width="38"
                                         Background="Transparent" Foreground="White"
                                         BorderThickness="0" FontSize="15" FontWeight="SemiBold"
                                         TextAlignment="Center" VerticalAlignment="Center"
                                         CaretBrush="White"/>
                                <TextBlock Text="min" Foreground="#888" FontSize="12"
                                           VerticalAlignment="Center" Margin="2,0,12,0"/>
                                <Button x:Name="StartPauseButton" Content="▶ Start"
                                        Background="#00CC6A" Style="{StaticResource PillButtonStyle}"
                                        Click="StartTimer_Click" Margin="0,0,6,0"/>
                                <Button Content="↺" Background="#555"
                                        Style="{StaticResource IconBtn}" FontSize="14"
                                        Click="ResetTimer_Click"/>
                            </StackPanel>

                            <!-- Stopwatch panel -->
                            <StackPanel x:Name="StopwatchPanel" Orientation="Horizontal"
                                        HorizontalAlignment="Center" Visibility="Collapsed">
                                <TextBlock x:Name="StopwatchDisplay" Text="00:00.0"
                                           Foreground="White" FontSize="22"
                                           FontWeight="Bold" FontFamily="Consolas"
                                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <Button x:Name="StopwatchStartBtn" Content="▶ Start"
                                        Background="#00CC6A" Style="{StaticResource PillButtonStyle}"
                                        Click="StopwatchStart_Click" Margin="0,0,6,0"/>
                                <Button Content="↺" Background="#555"
                                        Style="{StaticResource IconBtn}" FontSize="14"
                                        Click="StopwatchReset_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ═══ SYSTEM CONTROLS ═══ -->
                    <TextBlock x:Name="ControlsLabel" Text="CONTROLS" Foreground="#555" FontSize="10"
                               FontWeight="Bold" Margin="2,0,0,6"/>
                    <Border x:Name="ControlsBorder" Background="#2A2A2A" CornerRadius="10" Padding="12,8" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="VolumeIcon" Text="🔊" FontSize="14" Foreground="White"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider x:Name="VolumeSlider" Grid.Column="1"
                                        Minimum="0" Maximum="100" Value="50"
                                        VerticalAlignment="Center"
                                        ValueChanged="VolumeSlider_Changed"/>
                                <TextBlock x:Name="VolumeLabel" Grid.Column="2" Text="50%"
                                           Foreground="#888" FontSize="10"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="BrightnessIcon" Text="☀" FontSize="14" Foreground="White"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider x:Name="BrightnessSlider" Grid.Column="1"
                                        Minimum="0" Maximum="100" Value="100"
                                        VerticalAlignment="Center"
                                        ValueChanged="BrightnessSlider_Changed"
                                        ToolTip="May not be available on all displays"/>
                                <TextBlock x:Name="BrightnessLabel" Grid.Column="2" Text="100%"
                                           Foreground="#888" FontSize="10"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                            <WrapPanel HorizontalAlignment="Center">
                                <Button x:Name="LockBtn" Content="🔒 Lock" Background="#333"
                                        Style="{StaticResource PillButtonStyle}"
                                        Click="LockScreen_Click" Margin="0,0,6,4"/>
                                <Button x:Name="HibernateBtn" Content="❄ Hibernate" Background="#333"
                                        Style="{StaticResource PillButtonStyle}"
                                        Click="HibernatePC_Click" Margin="0,0,6,4"/>
                                <Button x:Name="ShutdownBtn" Content="⏻ Shut Down" Background="#333"
                                        Style="{StaticResource PillButtonStyle}"
                                        Click="ShutdownPC_Click" Margin="0,0,6,4"/>
                                <Button x:Name="RestartBtn" Content="🔄 Restart" Background="#333"
                                        Style="{StaticResource PillButtonStyle}"
                                        Click="RestartPC_Click" Margin="0,0,0,4"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- ═══ SYSTEM INFO ═══ -->
                    <TextBlock x:Name="SystemLabel" Text="SYSTEM" Foreground="#555" FontSize="10"
                               FontWeight="Bold" Margin="2,0,0,6"/>
                    <Border x:Name="SystemInfoBorder" Background="#2A2A2A" CornerRadius="10"
                            Padding="12,8" Margin="0,0,0,12">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,0">
                                <TextBlock x:Name="SysInfoBattery" Text="🔋 --%" Foreground="#CCC"
                                           FontSize="11" Margin="0,0,16,0"/>
                                <TextBlock x:Name="SysInfoCpu" Text="💻 CPU: --%" Foreground="#CCC"
                                           FontSize="11" Margin="0,0,16,0"/>
                                <TextBlock x:Name="SysInfoRam" Text="💾 RAM: --" Foreground="#CCC"
                                           FontSize="11"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- ═══ WORKSPACES ═══ -->
                    <Grid Margin="0,0,0,4">
                        <TextBlock x:Name="SubjectsLabel" Text="WORKSPACES" Foreground="#555" FontSize="10"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button x:Name="NewWorkspaceBtn" Content="+ New" Background="#2A2A2A"
                                HorizontalAlignment="Right"
                                Style="{StaticResource PillButtonStyle}"
                                Click="NewWorkspace_Click"/>
                    </Grid>
                    <WrapPanel x:Name="SubjectPanel" Margin="0,0,0,12"/>

                    <Border x:Name="SeparatorLine" Height="1" Background="#2A2A2A" Margin="0,0,0,10"/>

                    <!-- ═══ TEMPORARY SHELF ═══ -->
                    <TextBlock x:Name="TempShelfLabel" Text="TEMPORARY SHELF" Foreground="#555" FontSize="10"
                               FontWeight="Bold" Margin="2,0,0,4"/>
                    <TextBlock Text="Drag files here for quick access (cleared on restart)"
                               Foreground="#444" FontSize="9" FontStyle="Italic" Margin="2,0,0,4"/>
                    <Border x:Name="TempShelfDropZone" Background="#222" CornerRadius="8"
                            MinHeight="36" Padding="8,4" Margin="0,0,0,10"
                            AllowDrop="True" Drop="TempShelf_Drop"
                            DragEnter="ShelfDrag_Enter" DragLeave="ShelfDrag_Leave">
                        <ItemsControl x:Name="TempShelfList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Border>

                    <!-- ═══ PERMANENT SHORTCUTS ═══ -->
                    <Grid Margin="0,0,0,4">
                        <TextBlock x:Name="ShortcutsLabel" Text="SHORTCUTS" Foreground="#555" FontSize="10"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button x:Name="AddShortcutBtn" Content="+ Add" Background="#2A2A2A"
                                HorizontalAlignment="Right"
                                Style="{StaticResource PillButtonStyle}"
                                Click="AddShortcut_Click"/>
                    </Grid>
                    <Border x:Name="ShortcutDropZone" Background="#222" CornerRadius="8"
                            MinHeight="36" Padding="8,4" Margin="0,0,0,10"
                            AllowDrop="True" Drop="ShortcutZone_Drop"
                            DragEnter="ShelfDrag_Enter" DragLeave="ShelfDrag_Leave">
                        <ItemsControl x:Name="ShortcutList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Border>

                    <!-- ═══ DELETION ZONE ═══ -->
                    <Border x:Name="DeletionZone" Background="#331111" CornerRadius="8"
                            MinHeight="36" Padding="12,6" Margin="0,0,0,10"
                            AllowDrop="True" Drop="DeletionZone_Drop"
                            DragEnter="DeletionDrag_Enter" DragLeave="DeletionDrag_Leave">
                        <TextBlock x:Name="DeletionZoneText" Text="🗑  Drop files here to delete"
                                   Foreground="#FF6B6B" FontSize="11"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <Border Height="1" Background="#2A2A2A" Margin="0,0,0,10"/>

                    <!-- ═══ REMINDERS / TO-DO ═══ -->
                    <Grid Margin="0,0,0,4">
                        <TextBlock x:Name="RemindersLabel" Text="REMINDERS" Foreground="#555" FontSize="10"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button x:Name="AddReminderBtn" Content="+ Add" Background="#2A2A2A"
                                HorizontalAlignment="Right"
                                Style="{StaticResource PillButtonStyle}"
                                Click="AddReminder_Click"/>
                    </Grid>

                    <ItemsControl x:Name="ReminderList" Margin="0,0,0,4" MaxHeight="120">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2A2A2A" CornerRadius="8"
                                        Padding="10,5" Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="6" Height="6" Fill="#00FF88"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Text}"
                                                   Foreground="#CCC" FontSize="13"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Foreground="#777"
                                                   FontSize="10" VerticalAlignment="Center"
                                                   Margin="8,0,0,0">
                                            <TextBlock.Text>
                                                <Binding Path="AlertTime"
                                                         StringFormat="{}{0:h:mm tt}"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <Button Grid.Column="3" Content="✕" FontSize="10"
                                                Background="Transparent" Foreground="#888"
                                                BorderThickness="0" Cursor="Hand"
                                                Click="RemoveReminder_Click"
                                                Tag="{Binding}" VerticalAlignment="Center"
                                                Padding="4,0" Margin="4,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="NoRemindersText" Text="No reminders yet"
                               Foreground="#444" FontSize="11" FontStyle="Italic"
                               Margin="8,0,0,6"/>

                    <!-- Close -->
                    <Button Content="✕ Close App" Background="Transparent"
                            Foreground="#FF6B6B" BorderThickness="0" FontSize="11"
                            Cursor="Hand" Click="CloseApp_Click"
                            HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>