<Window x:Class="Orbital.ReminderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Reminder" Width="380" Height="240"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize">

    <Border Background="#1E1E1E" CornerRadius="16" Padding="20"
            BorderBrush="#333333" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.5"/>
        </Border.Effect>

        <StackPanel>
            <TextBlock Text="Add Timed Reminder" Foreground="White" FontSize="15"
                       FontWeight="SemiBold" Margin="0,0,0,12"/>

            <!-- Reminder text -->
            <Border Background="#2A2A2A" CornerRadius="8" Padding="2">
                <TextBox x:Name="ReminderInput" Background="Transparent"
                         Foreground="White" BorderThickness="0"
                         FontSize="14" Padding="10,8" CaretBrush="White"/>
            </Border>

            <!-- Alert time row -->
            <TextBlock Text="Remind me at:" Foreground="#AAA" FontSize="12"
                       Margin="0,12,0,4"/>
            <StackPanel Orientation="Horizontal">
                <Border Background="#2A2A2A" CornerRadius="8" Padding="2" Margin="0,0,6,0">
                    <TextBox x:Name="HourBox" Text="12" Width="36" Background="Transparent"
                             Foreground="White" BorderThickness="0" FontSize="14"
                             TextAlignment="Center" Padding="4,6" CaretBrush="White"/>
                </Border>
                <TextBlock Text=":" Foreground="White" FontSize="16"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Border Background="#2A2A2A" CornerRadius="8" Padding="2" Margin="0,0,6,0">
                    <TextBox x:Name="MinuteBox" Text="00" Width="36" Background="Transparent"
                             Foreground="White" BorderThickness="0" FontSize="14"
                             TextAlignment="Center" Padding="4,6" CaretBrush="White"/>
                </Border>
                <Button x:Name="AmPmButton" Content="PM" Click="ToggleAmPm_Click"
                        Cursor="Hand" Margin="6,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#333" CornerRadius="8"
                                    Padding="10,6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,14,0,0">
                <Button Click="Cancel_Click" Cursor="Hand" Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#333" CornerRadius="10"
                                    Padding="16,6">
                                <TextBlock Text="Cancel" Foreground="White" FontSize="13"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Click="Add_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#4A90D9" CornerRadius="10"
                                    Padding="16,6">
                                <TextBlock Text="Add" Foreground="White" FontSize="13"
                                           FontWeight="SemiBold"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#5AA0E9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
